#
# wm independent hotkeys
#

# audio
XF86Audio{Mute,LowerVolume,RaiseVolume}
    amixer set Master {toggle,5%-,5%+}

# brightness+
XF86MonBrightnessUp
	brightnessctl s 10%+

# brightness-
XF86MonBrightnessDown
	brightnessctl s 10%-

# calculator
XF86Calculator
	qalculate

# screenshots
Print
	maim ~/Pictures/Screenshots/$(date +%s).png

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# quit/restart bspwm
super + r
	bspc wm -r

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# terminal emulator
super + Return
	kitty

# program launcher
super + {_,shift + }@space
	{rofi -show drun,~/.eww/target/release/eww open --toggle powermenu}

# emoji launcher
super + ctrl + @space
	rofi -show emoji

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# focus or send the node to the given desktop
super + {_,shift + }{1-4}
	bspc {desktop -f,node -d} '^{1-4}'

# focus or send the node to the given direction
super + {_,shift + }{Left,Up,Down,Right}
	bspc node -{f,s} {west,north,south,east}

# Smart resize, will grow or shrink depending on location.
# Will always grow for floating nodes.
super + ctrl + {Left,Down,Up,Right}
  n=10; \
  { d1=left;   d2=right;  dx=-$n; dy=0;   \
  , d1=bottom; d2=top;    dx=0;   dy=$n;  \
  , d1=top;    d2=bottom; dx=0;   dy=-$n; \
  , d1=right;  d2=left;   dx=$n;  dy=0;   \
  } \
  bspc node --resize $d1 $dx $dy || bspc node --resize $d2 $dx $dy
