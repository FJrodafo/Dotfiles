#
# wm independent hotkeys
#

# screenshots
Print
	maim ~/Pictures/Screenshots/$(date +%s).png

# terminal emulator
super + Return
	kitty

# program launcher
super + {_,shift + }@space
	{rofi -show drun,~/eww/target/release/eww open --toggle powermenu}

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# quit/restart bspwm
super + {q,r}
	bspc {quit,wm -r}

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# focus or send the node to the given direction
super + {_,shift + }{Left,Up,Down,Right}
	bspc node -{f,s} {west,north,south,east}

# focus or send the node to the given desktop
super + {_,shift + }{1-4}
	bspc {desktop -f,node -d} '^{1-4}'
